# 포트
FRONTEND_PORT=14556
BACKEND_PORT=8000

# 데이터 파일 이름 (data/ 아래에 두세요)
DATASET_FILENAME=audit_cases.csv

# 백엔드 옵션
APP_NAME=Audit Action Recommender API
APP_VERSION=2.1.0
API_PREFIX=/api/v1
MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
AUTO_BUILD_ARTIFACTS=1
FORCE_REBUILD_ARTIFACTS=0
UVICORN_WORKERS=1

# 프론트엔드는 같은 컨테이너에서 /api/v1 로 프록시합니다.
VITE_API_BASE_URL=/api/v1

# 필요 시 CORS 허용 Origin을 추가할 수 있습니다.
ALLOWED_ORIGINS=http://localhost:14556,http://127.0.0.1:14556,http://125.183.175.200:14556

